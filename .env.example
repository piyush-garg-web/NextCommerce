# MongoDB Configuration
MONGODB_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# Authentication Configuration (JWT / Jose)
# Provide a strong secret key for signing cookies (e.g. generated via `openssl rand -base64 32`)
SECRET_KEY="your_jose_jwt_secret_key_here"

# SMTP Nodemailer Email Configuration (for OTP verification and order placement emails)
NODEMAILER_HOST="smtp.gmail.com"
NODEMAILER_PORT="587"
NODEMAILER_EMAIL="your_email@gmail.com"
NODEMAILER_PASSWORD="your_app_specific_email_password_here"

# Next.js Application Environment URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api"
NODE_ENV="development" # or "production"

# Cloudinary Integration (for image storage & media library uploads)
NEXT_PUBLIC_CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
CLOUDINARY_SECRET_KEY="your_cloudinary_secret_key_here"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your_cloudinary_preset_here"

# Razorpay Checkout Gateway Integration (currency: INR)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_razorpay_key_id_here"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"

# Google OAuth Configuration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth Configuration
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

